# ED_Mediawatch backend configuration
# Copy to .env and adjust.

# --- Database ---
# Local-first default = SQLite. To switch to Postgres/pgvector later:
#   DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/ed_mediawatch
DATABASE_URL=sqlite+aiosqlite:///./ed_mediawatch.db

# --- Nitter / X collection ---
# Comma-separated ordered fallback list. Health-checked at runtime.
NITTER_INSTANCES=https://nitter.net,https://nitter.poast.org,https://nitter.tiekoetter.com,https://nitter.catsarch.com,https://nitter.kareem.one
# Live health page used to refresh the working instance list (optional).
NITTER_HEALTH_URL=https://status.d420.de/api/v1/instances
# Self-hosted instance (recommended for sustained scraping). If set, tried first.
NITTER_SELF_HOSTED=

# Polite scraping
REQUEST_DELAY_SECONDS=2.5
REQUEST_TIMEOUT_SECONDS=20
MAX_CONCURRENT_REQUESTS=3
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36

# --- Scheduler ---
# How often to poll each personality's timeline (continuous collection).
COLLECTION_INTERVAL_HOURS=4
# Run a collection immediately on startup.
COLLECT_ON_STARTUP=false

# --- Sécurité (prod) ---
# Jeton requis (header X-API-Token) sur les endpoints coûteux. Vide = ouvert (dev).
API_TOKEN=
# Origines CORS autorisées en prod (CSV), ex. https://ed-mediawatch.vercel.app
# Vide = n'importe quel port localhost (dev).
CORS_ORIGINS=

# --- Pool ---
POOL_FILE=./data/pool_rn_udr.json

# --- Full-text extraction (press) ---
# Empty = local trafilatura. Set to the v2/media-watch scraper-service base URL
# (anti-paywall cascade) to route extraction through it, e.g. http://localhost:8080
EXTRACTOR_URL=

# --- Archivage / reçus (presse + X) ---
ARCHIVE_BACKEND=wayback           # wayback | local | archivebox | none
SNAPSHOT_DIR=./data/snapshots
ARCHIVE_RATE_SECONDS=1.5

# --- LLM : extraction de claims (tier-1 open + tier-2 fidélité) ---
# Renseigne au moins la clé du tier-2 pour activer le raffinage.
ANTHROPIC_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=                   # embeddings (blocking/pgvector, phase P2)

LLM_REFINE_ENABLED=false          # true = canonicalise les claims via LLM
CLAIM_TIER1_PROVIDER=groq         # filtre de masse (open) : groq|cerebras|mistral
CLAIM_TIER1_MODEL=llama-3.3-70b-versatile
CLAIM_TIER2_PROVIDER=anthropic    # fidélité : anthropic|mistral|groq|cerebras
CLAIM_TIER2_MODEL=claude-haiku-4-5
