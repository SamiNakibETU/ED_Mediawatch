# Configuration du scraper-service ED_Mediawatch (anti-paywall presse FR)
# Copier ce fichier en .env et remplir les valeurs

# Service
LOG_LEVEL=INFO
PORT=8080

# Scraping
MAX_RETRIES=5
REQUEST_TIMEOUT=120
MIN_ARTICLE_WORDS=150
TARGET_ARTICLE_WORDS=500

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_DEFAULT_TIMEOUT=90000
PLAYWRIGHT_NAVIGATION_TIMEOUT=120000
PLAYWRIGHT_MAX_SCROLLS=15

# Services externes
JINA_AI_ENABLED=true
JINA_AI_API_KEY=              # Optionnel mais recommandé
JINA_AI_TIMEOUT=45

SCRAPLING_ENABLED=true
SCRAPLING_SOLVE_CF=true

# Cache
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600

# Rate limiting
RATE_LIMIT_BASE_DELAY=1.5
RATE_LIMIT_MAX_DELAY=120

# Feature flags
VERIFY_COMPLETENESS=true
COMPLETENESS_THRESHOLD=0.95
SAVE_FAILED_HTML=false
DEBUG_MODE=false

# LLM cleanup (tier final paywall, T6) — ED_Mediawatch défaut = Cerebras
# (Groq bloqué). Laisser la clé vide pour DÉSACTIVER ce tier.
CEREBRAS_API_KEY=
SCRAPER_LLM_CLEANUP_MODEL=gpt-oss-120b
SCRAPER_LLM_CLEANUP_BASE_URL=https://api.cerebras.ai/v1
